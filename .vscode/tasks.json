				"clear": true,
				"close": true
			}
		},
		{
			"label": "test-multer",
			"type": "shell",
			"command": "node",
			"args": [
				"-e",
				"require(\"./src/routes/chatRoutes\"); require(\"./src/routes/userRoutes\"); require(\"./src/routes/verificationRoutes\"); console.log(\"ALL-OK\")"
			],
			"presentation": {
				"reveal": "never",
				"panel": "shared",
				"clear": true,
				"close": true
			}
		},
		{
			"label": "backend-chat-static-sanity",
			"type": "shell",
