			"args": [
				"-e",
				"require('./src/services/paymentProviders/stripeProvider'); require('./src/services/paymentService'); require('./src/controllers/paymentController'); require('./src/routes/paymentRoutes'); console.log('payments-backend-ok')"
			],
			"isBackground": false,
			"presentation": {
				"reveal": "never",
				"panel": "shared",
